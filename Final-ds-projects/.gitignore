# =========================
# Python / Virtualenv
# =========================
.venv/
.venv_ui/
venv/
ENV/
.env
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# Large ML artifacts (DO NOT COMMIT)
# =========================
# Ignore all model directories anywhere in the umbrella repo
**/models/**

# Safety net: ignore common checkpoint / weight formats anywhere
**/checkpoint-*/
**/*.safetensors
**/*.bin
**/*.pt
**/*.pth
**/optimizer.pt
**/scheduler.pt
**/trainer_state.json
**/training_args.bin

# Ignore legacy monolithic scripts folder (keep ref locally)
**/legacy/**

# Temporary eval scratch folders
**/_tmp_eval*/
**/_eval_tmp*/
**/_tmp_eval_transfer*/

# Zip artifacts (often huge)
**/*.zip

# Experiment trackers (if created)
**/wandb/
**/mlruns/
**/runs/

# =========================
# Allow small placeholder docs inside models/
# (so repo users know where to put downloaded checkpoints)
# =========================
!**/models/
!**/models/**/PLACE_YOUR_MODEL_HERE.txt
!**/models/**/README.md
!**/models/**/.gitkeep
