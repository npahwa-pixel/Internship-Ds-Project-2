# Python / env
.venv/
.venv_ui/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editor
.DS_Store
.vscode/
.idea/

# Ignore model artifacts everywhere (keep placeholders allowed)
**/models/**
!**/models/**/.gitkeep
!**/models/**/PLACE_*.txt
!**/models/**/README*.md

# Big checkpoint files
**/checkpoint-*/
**/*.safetensors
**/*.bin
**/*.pt
**/*.pth
**/optimizer.pt
**/scheduler.pt
**/trainer_state.json
**/training_args.bin

# temp eval dirs
**/_tmp_eval*/
**/_tmp_eval_transfer*/
**/_eval_tmp*/

# Keep legacy scripts but ignore heavy artifacts inside legacy
**/legacy/**/checkpoint-*/
**/legacy/**/*.safetensors
**/legacy/**/*.pt
**/legacy/**/*.pth
**/legacy/**/*.bin

# zips
**/*.zip
