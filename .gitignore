# =========================================================
# Internship-Ds-Project-2 — .gitignore (models excluded, configs allowed)
# =========================================================

# -------------------------
# Python / Virtual env
# -------------------------
.venv/
.venv_ui/
venv/
ENV/
env/

# -------------------------
# Python cache / tooling
# -------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# -------------------------
# Jupyter
# -------------------------
.ipynb_checkpoints/

# -------------------------
# OS / Editor
# -------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# Logs / temp
# -------------------------
*.log
*.tmp
*.temp

# =========================================================
# MODEL ARTIFACTS (DO NOT COMMIT)
# =========================================================

# HuggingFace / Torch weights
**/*.safetensors
**/*.pt
**/*.pth
**/*.bin

# Trainer state / optimizer artifacts
**/optimizer.pt
**/scheduler.pt
**/rng_state.pth
**/trainer_state.json
**/training_args.bin

# Common HF checkpoint folders
**/checkpoint-*/
**/_tmp_eval*/
**/_tmp_eval_transfer*/
**/_eval_tmp*/

# Tokenizers / caches that can explode (keep configs below)
**/.cache/
**/wandb/
**/mlruns/

# Zips / large archives
**/*.zip
**/*.tar.gz
**/*.tgz
**/*.7z

# Legacy folder (keep code locally; not needed in repo)
**/legacy/**

# =========================================================
# MODELS FOLDER RULE (configs allowed, weights blocked above)
# =========================================================
# Ignore everything under any models/ folder...
**/models/**

# ...but keep lightweight config artifacts + placeholders
!**/models/**/.gitkeep
!**/models/**/README*.md
!**/models/**/PLACE*.txt
!**/models/**/config.json
!**/models/**/adapter_config.json
!**/models/**/tokenizer.json
!**/models/**/tokenizer_config.json
!**/models/**/special_tokens_map.json
!**/models/**/added_tokens.json
!**/models/**/spm.model

# (Optional) keep label/schema files if you store them beside configs
!**/models/**/labels*.json
!**/models/**/schema*.json
